{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "base",
					"color": "#FAF8F4",
					"name": "Off-white"
				},
				{
					"slug": "secondary",
					"color": "#F1F0EC",
					"name": "Bege"
				},
				{
					"slug": "surface",
					"color": "#F1F0EC",
					"name": "Bege"
				},
				{
					"slug": "contrast",
					"color": "#484241",
					"name": "Marrom"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "Branco"
				},
				{
					"slug": "primary",
					"color": "#484241",
					"name": "Marrom"
				},
				{
					"slug": "accent",
					"color": "#484241",
					"name": "Marrom"
				},
				{
					"slug": "border",
					"color": "#E0DED8",
					"name": "Borda"
				},
				{
					"slug": "muted",
					"color": "#6A6A6A",
					"name": "Texto secundário"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Prata, \"Times New Roman\", Georgia, serif",
					"slug": "primaria",
					"name": "Primária"
				},
				{
					"fontFamily": "Raleway, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
					"slug": "secundaria",
					"name": "Secundária"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Pequeno"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Médio"
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Grande"
				},
				{
					"slug": "x-large",
					"size": "1.5rem",
					"name": "Extra grande"
				},
				{
					"slug": "xx-large",
					"size": "2.25rem",
					"name": "XX grande"
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vh", "vw"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--muted)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--secundaria)",
			"fontSize": "var(--wp--preset--font-size--medium)"
		},
		"elements": {
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primaria)",
					"fontWeight": "600",
					"lineHeight": "1.2"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primaria)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secundaria)"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secundaria)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--secundaria)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--primaria)"
				}
			}
		}
	}
}
